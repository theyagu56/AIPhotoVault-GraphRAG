# ── .NET ─────────────────────────────────────────────────
bin/
obj/
*.user
*.suo
.vs/
*.log

# ── Secrets — NEVER commit real keys ─────────────────────
appsettings.*.json
!appsettings.Development.json

# ── Node / Next.js ────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env
frontend/.env.local
frontend/.env*.local

# ── SQLite databases ──────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── macOS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Project data folder (db + thumbnails — too large for git) ─
data/MediaRoot/Application/Database/
data/MediaRoot/Application/Thumbnails/
data/MediaRoot/Application/Cache/
# Keep the folder structure itself
!data/MediaRoot/Application/.gitkeep
